@prefix dct:   <http://purl.org/dc/terms/> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<https://pod.rubendedecker.be/scholar/projects/deployEMDS/catalogs/dataset_catalog#Catalog> dcat:dataset <https://pod.rubendedecker.be/scholar/projects/deployEMDS/datasets/sample_dataset4>.
<https://pod.rubendedecker.be/scholar/projects/deployEMDS/datasets/sample_dataset4> a dcat:Dataset;
    dct:title "Synthetic prediction sample The Loop"@en ;
    dct:description "Synthetic prediction sample of traffic at The Loop"@en ;
    dcat:keyword "mobility", "traffic", "prediction", "synthetic" ;
